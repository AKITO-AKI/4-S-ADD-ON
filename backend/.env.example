# Copy this file to .env and fill in real values before running the server.

# --- JWT ---
JWT_SECRET_KEY=CHANGE_ME_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/foursdb

# --- S3-compatible Storage ---
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=YOUR_ACCESS_KEY
S3_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
S3_BUCKET_NAME=4s-cloud-studio
S3_REGION_NAME=us-east-1

# --- App ---
DEBUG=false
# Comma-separated list of allowed CORS origins. Use * to allow all (development only).
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
